# MySQL 连接串：mysql://用户名:密码@主机:端口/数据库名
# 示例：mysql://root:123456@localhost:3306/resume_power_station
# 服务器部署时请改成真实 MySQL 配置。
DATABASE_URL="mysql://user:password@localhost:3306/resume_power_station"

# Redis 连接串：redis://[:密码@]主机:端口/数据库编号
# 无密码本地 Redis 示例：redis://localhost:6379/0
# 有密码 Redis 示例：redis://:your_redis_password@127.0.0.1:6379/0
REDIS_URL="redis://localhost:6379/0"

# 后端服务端口。
PORT=3001

# 前端访问地址，用于邮件链接、跨域和 Cookie 场景。
APP_BASE_URL="http://localhost:3000"

# CORS 白名单，多个来源用英文逗号分隔。
WEB_ORIGIN="http://localhost:3000,http://localhost:5173"

# development / production。
NODE_ENV="development"

# OpenAI-compatible AI 配置。
# DeepSeek 官方可用：https://api.deepseek.com
# 其他兼容网关请填写网关提供的 base url，通常以 /v1 结尾或由服务商说明。
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.deepseek.com"

# 模型名称请以你的服务商控制台为准。
# DeepSeek 官方常见模型：deepseek-chat / deepseek-reasoner。
# 如果你的服务商提供 flash/pro 档，可填写对应模型名，例如 deepseek-v4-flash / deepseek-v4-pro。
OPENAI_MODEL_ANALYSIS="deepseek-chat"
OPENAI_MODEL_OPTIMIZE="deepseek-chat"
OPENAI_MODEL_FAST_OPTIMIZE="deepseek-chat"

# 快速模式：一次 AI 调用返回分析 + 优化结构，推荐生产开启。
AI_FAST_MODE="true"

# AI 请求超时时间，单位毫秒。300000 = 5 分钟。
AI_REQUEST_TIMEOUT_MS=300000

# 传给 AI 的简历正文上限。过小会导致长简历后半段经历缺失。
AI_MAX_RESUME_CHARS=12000

# 传给 AI 的岗位 JD 上限。
AI_MAX_JD_CHARS=5000

# AI 最大输出 token。
# 0 表示后端不传 max_tokens，让模型按服务商上限尽量完整输出。
# 注意：模型仍有上下文窗口硬上限，不存在真正无限输出。
AI_MAX_OUTPUT_TOKENS=0

# 本地假数据模式。true 时不调用真实 AI，适合无 Key 开发。
MOCK_AI="false"

# SMTP 邮箱配置。
# 163 邮箱示例：
# SMTP_HOST="smtp.163.com"
# SMTP_PORT=465
# SMTP_SECURE="true"
# SMTP_USER="你的邮箱@163.com"
# SMTP_PASS="邮箱授权码，不是网页登录密码"
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="简历发电站 <no-reply@example.com>"

# 邮箱验证码配置：验证码存 Redis，不写入 MySQL。
# 默认 300 秒有效，同邮箱同场景 60 秒内只能发送一次。
EMAIL_CODE_EXPIRES_SECONDS=300
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5
EMAIL_CODE_MAX_PER_EMAIL_HOUR=10
EMAIL_CODE_MAX_PER_IP_HOUR=30

# 上传文件大小，单位 MB。
UPLOAD_MAX_SIZE_MB=10

# 普通用户每日免费优化次数，由服务端鉴权后计算。
DAILY_OPTIMIZE_LIMIT=3

# 赞助入口。
AFDIAN_URL="https://afdian.com/a/yourname"

# PDF 导出开关。
ENABLE_PDF_EXPORT="true"
